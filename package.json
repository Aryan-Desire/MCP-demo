{
  "name": "mcp-demo",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.14.0 < 23.0.0"
  },
  "scripts": {
    "tw:build": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/dist/tailwind.css --minify",
    "tw:watch": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/dist/tailwind.css --watch",
    "serve": "heft start",
    "build": "heft test --clean --production && heft package-solution --production",
    "clean": "heft clean",
    "dev": "concurrently \"npm run tw:watch\" \"npm run serve\""
  },
  "dependencies": {
    "@fluentui/react": "^8.106.4",
    "@microsoft/sp-component-base": "1.23.0",
    "@microsoft/sp-core-library": "1.23.0",
    "@microsoft/sp-lodash-subset": "1.23.0",
    "@microsoft/sp-office-ui-fabric-core": "1.23.0",
    "@microsoft/sp-property-pane": "1.23.0",
    "@microsoft/sp-webpart-base": "1.23.0",
    "@pnp/core": "^4.20.0",
    "@pnp/sp": "^4.20.0",
    "@pnp/spfx-controls-react": "^3.24.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "tslib": "2.3.1"
  },
  "devDependencies": {
    "@microsoft/eslint-config-spfx": "1.23.0",
    "@microsoft/eslint-plugin-spfx": "1.23.0",
    "@microsoft/sp-module-interfaces": "1.23.0",
    "@microsoft/spfx-heft-plugins": "1.23.0",
    "@microsoft/spfx-web-build-rig": "1.23.0",
    "@rushstack/heft": "1.2.17",
    "@types/jest": "30.0.0",
    "@types/react": "17.0.45",
    "@types/react-dom": "17.0.17",
    "@types/webpack-env": "~1.15.2",
    "concurrently": "^10.0.3",
    "css-loader": "~7.1.2",
    "eslint": "9.37.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.0"
  },
  "overrides": {
    "@rushstack/heft": "1.2.17"
  },
  "resolutions": {
    "@types/react": "17.0.45"
  }
}
